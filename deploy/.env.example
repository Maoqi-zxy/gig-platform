# ===========================================
# 灵活用工平台 - 环境变量模板
# ===========================================
# 复制此文件为 .env.local 并填入实际值
# 切勿将真实的 .env.local 提交到 Git!

# ===========================================
# 前端环境变量 (Vercel)
# ===========================================

# 后端 API 地址 (生产环境)
NEXT_PUBLIC_API_URL=https://flex-gig-api.railway.app

# 环境标识 (development | staging | production)
NEXT_PUBLIC_ENV=production

# Sentry 错误追踪 (可选)
NEXT_PUBLIC_SENTRY_DSN=

# 功能开关
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_SENTRY=false

# ===========================================
# 后端环境变量 (Railway)
# ===========================================

# 运行环境
NODE_ENV=production

# 服务端口
PORT=3000

# MongoDB 数据库连接 (从 MongoDB Atlas 获取)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxx.mongodb.net/flex-gig?retryWrites=true&w=majority

# JWT 密钥 (使用 openssl rand -hex 32 生成)
JWT_SECRET=

# JWT 过期时间
JWT_EXPIRES_IN=7d

# CORS 配置 (允许的前端域名)
CORS_ORIGIN=https://flex-gig-platform.vercel.app

# 日志级别 (error | warn | info | debug)
LOG_LEVEL=info

# ===========================================
# 第三方服务密钥 (按需配置)
# ===========================================

# 短信服务 (阿里云 SMS)
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# 对象存储 (阿里云 OSS / AWS S3)
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=

# 支付 (Stripe / 支付宝)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 邮件服务 (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@flexgig.com

# ===========================================
# 监控和调试
# ===========================================

# Sentry (后端)
SENTRY_DSN=
SENTRY_ENV=production

# 开发调试
DEBUG=false
DEBUG_CONSOLE=false